package arrays;

public class prefixarray {
	static int rangesum(int arr[], int k) {
		int sum = 0;

		for (int i = 0; i <= k; i++) {
			sum += arr[i];
		}
		return sum;
	}

	static void prefixArray(int arr[]) {
		int prefix[] = new int[arr.length];

		prefix[0] = arr[0];

		for (int i = 1; i < arr.length; i++) {
			prefix[i] = prefix[i - 1] + arr[i];
		}

		for (int x : prefix)
			System.out.print(x + " ");
	}

	public static void main(String args[]) {
		int arr[] = { 1, 2, 3 };
		System.out.println(rangesum(arr, 3));

	}
}
