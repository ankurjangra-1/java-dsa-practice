package arrays;

public class SubarraySum {
 static void subarrays(int arr[],int k) {
	 int sum=Integer.MIN_VALUE;
	 int count=0;
	 for(int i=0;i<arr.length;i++) {
		sum+=arr[i];
		if(sum==k) {
			count++;
		}
	 }
 }
 public static void main(String args[]) {
	 int arr[]= {1,2,3};
	 subarrays(arr,3);
 }
}
