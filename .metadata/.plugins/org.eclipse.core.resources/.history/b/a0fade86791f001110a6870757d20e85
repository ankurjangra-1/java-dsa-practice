package arrays;

public class SlidingWindow {
	static void MaximumSumSubarraySizeK(int arr[],int k) {
		int windowsum=0;
		int maxsum=0;
		for(int i=0;i<k;i++) 
			windowsum +=arr[i];
		
			maxsum=windowsum;
		for(int i=k;i<arr.length;i++) {
			windowsum =windowsum -arr[i-k]+arr[k];
			 maxsum= Math.max(maxsum, windowsum);
		}
	}

}
